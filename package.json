{
  "name": "nearbytes-engine",
  "version": "0.1.0",
  "description": "Shared NearBytes core engine — runtime, sync, config, file & chat operations reused by the CLI (terminal shell) and the desktop app (UI shell).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "refresh": "node scripts/refresh.mjs",
    "prepare": "tsc",
    "prepack": "tsc",
    "build": "tsc",
    "dev": "node scripts/dev-bootstrap.mjs && tsc --watch --preserveWatchOutput",
    "dev:fast": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-chat": "github:nearbytes/nearbytes-chat",
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto",
    "nearbytes-files": "https://github.com/nearbytes/nearbytes-files.git#commit=29c7def6488f0366fab1e0fbe17bc697a97e5400",
    "nearbytes-log": "https://github.com/nearbytes/nearbytes-log.git#commit=f95575fdb7f5ce5e383870d3a6977a8a7820c567",
    "nearbytes-skeleton": "github:nearbytes/nearbytes-skeleton",
    "nearbytes-sync": "github:nearbytes/nearbytes-sync"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
