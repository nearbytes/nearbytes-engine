{
  "name": "nearbytes-engine",
  "version": "0.1.0",
  "description": "Shared NearBytes core engine — runtime, sync, config, file & chat operations reused by the CLI (terminal shell) and the desktop app (UI shell).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "refresh": "node scripts/refresh.mjs",
    "prepare": "tsc",
    "prepack": "tsc",
    "build": "tsc",
    "dev": "node scripts/dev-bootstrap.mjs && tsc --watch --preserveWatchOutput",
    "dev:fast": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-chat": "https://github.com/nearbytes/nearbytes-chat.git#commit=6892ff741b7af37796b529d04cbb00fe2064f3d3",
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto",
    "nearbytes-files": "https://github.com/nearbytes/nearbytes-files.git#commit=a6acbacdea36661b3e4ba10142bf8db1cefb0ba6",
    "nearbytes-log": "https://github.com/nearbytes/nearbytes-log.git#commit=0a1bef159ead34b542d20af74b8473e2232a90e2",
    "nearbytes-skeleton": "https://github.com/nearbytes/nearbytes-skeleton.git#commit=5bd31a80be2289533347da6211402f260c94a01c",
    "nearbytes-sync": "https://github.com/nearbytes/nearbytes-sync.git#commit=3753303a82171efd21ba39f8797a7886e2a57eca"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
