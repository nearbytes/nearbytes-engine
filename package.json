{
  "name": "nearbytes-engine",
  "version": "0.1.0",
  "description": "Shared NearBytes core engine — runtime, sync, config, file & chat operations reused by the CLI (terminal shell) and the desktop app (UI shell).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "refresh": "node scripts/refresh.mjs",
    "prepare": "tsc",
    "prepack": "tsc",
    "build": "tsc",
    "dev": "node scripts/dev-bootstrap.mjs && tsc --watch --preserveWatchOutput",
    "dev:fast": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-chat": "portal:../nearbytes-chat",
    "nearbytes-crypto": "portal:../nearbytes-crypto",
    "nearbytes-files": "portal:../nearbytes-files",
    "nearbytes-log": "portal:../nearbytes-log",
    "nearbytes-skeleton": "portal:../nearbytes-skeleton",
    "nearbytes-sync": "portal:../nearbytes-sync"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0",
  "resolutions": {
    "nearbytes-crypto": "portal:../nearbytes-crypto",
    "nearbytes-log": "portal:../nearbytes-log",
    "nearbytes-sync": "portal:../nearbytes-sync",
    "nearbytes-skeleton": "portal:../nearbytes-skeleton",
    "nearbytes-chat": "portal:../nearbytes-chat",
    "nearbytes-files": "portal:../nearbytes-files"
  }
}
